---
import { strings, MAIL, type Lang } from "../i18n/strings";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = strings[lang];
---

<section class="hero">
  <div class="container hero__inner">
    <!-- Wordmark monoespaciado + cursor/bloque dorado -->
    <h1 class="wordmark" aria-label="aigralys">
      <span class="wordmark__text">aigralys</span><span
        class="wordmark__cursor"
        aria-hidden="true"></span>
    </h1>

    <!-- Tagline tipo comentario de código, flechas en dorado -->
    <p class="tagline mono">
      <span class="muted">//</span> build <span class="gold">→</span> ship
      <span class="gold">→</span> repeat.
    </p>

    <!-- Una línea de qué es -->
    <p class="lede">{t.hero.subtitle}</p>

    <!-- CTA suave doble -->
    <nav class="cta" aria-label={t.nav.products}>
      <a class="btn btn--primary mono" href="#products">{t.hero.ctaProducts}</a>
      <a class="btn btn--ghost mono" href={`mailto:${MAIL}`}>{t.hero.ctaContact}</a>
    </nav>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    min-height: 100svh;
    padding-block: clamp(5rem, 16vh, 9rem);
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ---------- wordmark ---------- */
  .wordmark {
    font-family: var(--mono);
    font-weight: 700;
    font-size: clamp(2.5rem, 12vw, 5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
    display: inline-flex;
    align-items: center;
  }

  .wordmark__cursor {
    display: inline-block;
    width: 0.5em;
    height: 0.92em;
    /* 4-6px de aire entre la "s" y el cursor, escalando con la tipografía */
    margin-left: clamp(4px, 0.1em, 6px);
    background: var(--gold);
    translate: 0 0.04em;
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wordmark__cursor {
      animation: none;
    }
  }

  /* ---------- tagline ---------- */
  .tagline {
    font-size: clamp(1rem, 3.5vw, 1.4rem);
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--ink);
  }

  /* ---------- lede ---------- */
  .lede {
    font-size: clamp(1.05rem, 3.6vw, 1.35rem);
    color: var(--slate);
    max-width: 34ch;
  }

  /* ---------- CTA ---------- */
  .cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    font-size: 0.95rem;
    padding: 0.6rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    transition:
      border-color 0.15s ease,
      color 0.15s ease,
      background-color 0.15s ease;
  }

  .btn--primary {
    color: var(--navy);
    background: var(--gold);
    border-color: var(--gold);
  }

  .btn--primary:hover {
    background: #eab863;
    border-color: #eab863;
  }

  .btn--ghost {
    color: var(--ink);
    background: transparent;
  }

  .btn--ghost:hover {
    border-color: var(--gold);
    color: var(--gold);
  }
</style>
